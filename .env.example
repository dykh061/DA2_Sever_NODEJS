PORT=3000

# Option 1 (recommended): single MySQL connection string
# Example: mysql://root:password@localhost:3306/demo_nodejs
DB_URL=

# Option 2: separated database variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=demo_nodejs

# Optional settings
DB_CONNECTION_LIMIT=10
DB_SSL=false
